DELTA_API_KEY=
DELTA_API_SECRET=
DELTA_BASE_URL=https://api.india.delta.exchange

# Live Trading / Auto-Restart Settings (used by start.sh and render.yaml)
BOT_MODE=dry-run
# You can run multiple instances by separating symbols with a comma (e.g., BTCUSD,ETHUSD)
TRADE_SYMBOL=BTCUSD,ETHUSD
TRADE_INTERVAL=300